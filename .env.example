# ── Base de datos (Railway la inyecta automática si agregás el plugin Postgres) ──
DATABASE_URL="postgresql://user:password@localhost:5432/trainy"

# ── NextAuth ──
# Generar con: openssl rand -base64 32
AUTH_SECRET="cambiame"
# URL pública de la app (en Railway: https://<tu-app>.up.railway.app)
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ── Google OAuth (OPCIONAL — si no se configura, la app usa email+password) ──
# Crear credenciales en https://console.cloud.google.com/apis/credentials
# Redirect URI: <AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── API key para importar planes desde el skill Trainy (POST /api/import) ──
# Generar con: openssl rand -hex 24
TRAINY_API_KEY="cambiame"

# ── Coach IA + generador de planes (OPCIONAL — sin esto no aparecen) ──
# Key de https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=""
# Modelo del coach (default: claude-sonnet-5)
COACH_MODEL=""

# ── Login con código por email (OPCIONAL — sin esto la opción se oculta) ──
# Key de https://resend.com → API Keys. Free tier: 3.000 emails/mes.
# Con dominio propio verificado en Resend, poné EMAIL_FROM="Trainy <no-reply@tudominio.com>"
RESEND_API_KEY=""
EMAIL_FROM=""
